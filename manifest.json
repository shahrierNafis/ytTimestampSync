{
    "manifest_version": 3,
    "name": "YouTube Timestamp Updater",
    "version": "1.0",
    "description": "Updates the ?t=seconds parameter in the URL while watching YouTube videos.",
    "permissions": [
        "tabs",
        "scripting"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/watch*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}