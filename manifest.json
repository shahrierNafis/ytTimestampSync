{
    "manifest_version": 3,
    "name": "YouTube Timestamp Sync",
    "version": "1.1",
    "description": "Remembers your playback position on YouTube and prompts you to continue where you left off.",
    "permissions": [
        "storage"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/watch*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}
